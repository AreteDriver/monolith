# Monolith Configuration
# Copy to .env and fill in values

# Sui chain configuration (required for live data)
# Package ID changes each cycle — get from CCP or /config endpoint
MONOLITH_SUI_PACKAGE_ID=
# MONOLITH_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# MONOLITH_CHAIN_POLL_INTERVAL=30

# Anthropic API key (optional — enables LLM plain English narration)
MONOLITH_ANTHROPIC_API_KEY=

# Discord webhook URL (optional — enables CRITICAL/HIGH alerts)
MONOLITH_DISCORD_WEBHOOK_URL=

# Database path (default: monolith.db in working directory)
# MONOLITH_DATABASE_PATH=monolith.db

# Polling intervals in seconds (defaults shown)
# MONOLITH_SNAPSHOT_INTERVAL=900
# MONOLITH_DETECTION_INTERVAL=300
