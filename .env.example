# Monolith Configuration
# Copy to .env and fill in values

# Chain environment: "stillness" (mainnet) or "nova" (testnet/sandbox)
MONOLITH_CHAIN=stillness

# Sui package ID — auto-fetched from World API /config if not set.
# Override here if /config is unreachable or for pinning to a specific cycle.
# MONOLITH_SUI_PACKAGE_ID=0xd12a70c74c1e759445d6f209b01d43d860e97fcf2ef72ccbbd00afd828043f75

# Sui RPC URL — auto-resolved from chain setting if not set
# MONOLITH_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# World API URL — auto-resolved from chain setting if not set
# MONOLITH_WORLD_API_URL=https://blockchain-gateway-stillness.live.tech.evefrontier.com

# Anthropic API key (optional — enables LLM plain English narration)
MONOLITH_ANTHROPIC_API_KEY=

# Discord webhook URL (optional — enables CRITICAL/HIGH alerts)
MONOLITH_DISCORD_WEBHOOK_URL=

# Database path (default: monolith.db in working directory)
# MONOLITH_DATABASE_PATH=monolith.db

# Polling intervals in seconds (defaults shown)
# MONOLITH_CHAIN_POLL_INTERVAL=30
# MONOLITH_SNAPSHOT_INTERVAL=900
# MONOLITH_DETECTION_INTERVAL=300
# MONOLITH_STATIC_DATA_INTERVAL=3600
